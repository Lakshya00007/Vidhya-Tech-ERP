{
  "name": "school-erp-desktop",
  "productName": "School ERP Desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron": "wait-on http://localhost:5173 && electron electron/main.cjs",
    "desktop": "concurrently \"npm run dev\" \"npm run electron\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "test:database": "electron electron/database-smoke.cjs",
    "postinstall": "npm run rebuild:native"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.3",
    "electron": "^41.7.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  }
}
